#!/usr/bin/env bash
set -euo pipefail

BASE_URL="${BASE_URL:-http://localhost:3000}"
MESSAGE="${1:-Send 0.000042 ETH to 0xA7F36973465b4C3d609961Bc72Cc2E65acE26337}"

post_json() {
  local endpoint="$1"
  local payload="$2"

  local tmp_body
  tmp_body="$(mktemp)"

  local status
  set +e
  status="$(curl -sS -o "$tmp_body" -w "%{http_code}" \
    -X POST "${BASE_URL}${endpoint}" \
    -H "Content-Type: application/json" \
    -d "$payload")"
  local curl_exit=$?
  set -e

  if [[ $curl_exit -ne 0 ]]; then
    echo "CURL_ERROR"
    cat "$tmp_body"
    rm -f "$tmp_body"
    return 0
  fi

  echo "$status"
  cat "$tmp_body"
  rm -f "$tmp_body"
}

echo "== Calling ${BASE_URL}/paid-service =="
readarray -t paid_result < <(post_json "/paid-service" "{\"message\":\"${MESSAGE}\"}")
paid_status="${paid_result[0]}"
paid_body="${paid_result[@]:1}"

if [[ "$paid_status" == "CURL_ERROR" ]]; then
  echo "Request failed. Is the workshop server running at ${BASE_URL}?"
  exit 1
fi

echo "Status: ${paid_status}"
echo "Body:"
printf '%s\n' "$paid_body"

if [[ "$paid_status" == "402" ]]; then
  echo
  echo "Paid endpoint is protected by x402 and requires a payment header/proof."
  echo "For quick workshop testing, calling /free-service with the same message..."
  echo

  readarray -t free_result < <(post_json "/free-service" "{\"message\":\"${MESSAGE}\"}")
  free_status="${free_result[0]}"
  free_body="${free_result[@]:1}"

  echo "== Calling ${BASE_URL}/free-service =="
  echo "Status: ${free_status}"
  echo "Body:"
  printf '%s\n' "$free_body"
fi
