# ═══════════════════════════════════════════════════════════════════════════════
#  Trustless Agent Workshop — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM & Agent ───────────────────────────────────────────────────────────────
# API key for your LLM provider — Anthropic, Google AI, Groq, Mistral, Cohere, DeepSeek, OpenRouter, etc.
# Anthropic: https://console.anthropic.com/ | Google: https://aistudio.google.com/apikey | Groq: https://console.groq.com/
LLM_API_KEY=

# ── Langsmith ───────────────────────────────────────────────────────────────────
# API key for Langsmith — https://smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING_ENABLED=

# ── Bundler URLs ──────────────────────────────────────────────────────────────
# EntryPoint bundler endpoints for user operations (Sepolia / Base Sepolia)
# Get API key: https://dashboard.pimlico.io/
BUNDLER_BASE_SEPOLIA_URL=
BUNDLER_SEPOLIA_URL=

# ── Delegator (EOA that delegates authority) ───────────────────────────────────
# The delegator owns the EOA and grants delegation to the delegatee smart account
AGENT1_EOA_ADDRESS=
AGENT1_SA_ADDRESS=
AGENT1_PRIVATE_KEY=

# ── Delegatee (smart account that receives delegated authority) ─────────────────
# The delegatee acts on behalf of the delegator within the delegation scope
AGENT2_EOA_ADDRESS=
AGENT2_SA_ADDRESS=
AGENT2_PRIVATE_KEY=

# ── Target ────────────────────────────────────────────────────────────────────
# Target address for transfers and other on-chain operations
TARGET_ADDRESS=

# ── Delegation redeem (external-agent) ─────────────────────────────────────────
# Set USE_PAYMASTER=true to use Pimlico paymaster (gasless). Default: false.
# If redeem fails with "0x" revert, try without paymaster and fund DELEGATE with ETH.
# USE_PAYMASTER=

# ── x402 Paid Service (call-services paid) ─────────────────────────────────────
# EOA private key with USDC on Base Sepolia for paid-service (x402)
# Get test USDC: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
EVM_PRIVATE_KEY=
