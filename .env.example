# ═══════════════════════════════════════════════════════════════════════════════
#  Trustless Agent Workshop — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM & Agent ───────────────────────────────────────────────────────────────
# API key for your LLM provider (OpenAI, Anthropic, etc.) — used by the agent runtime
LLM_API_KEY=

# ── Bundler URLs ──────────────────────────────────────────────────────────────
# EntryPoint bundler endpoints for user operations (Sepolia / Base Sepolia)
BUNDLER_BASE_SEPOLIA_URL=
BUNDLER_SEPOLIA_URL=

# ── Delegator (EOA that delegates authority) ───────────────────────────────────
# The delegator owns the EOA and grants delegation to the delegatee smart account
DELEGATOR_EOA_ADDRESS=
DELEGATOR_SA_ADDRESS=
DELEGATOR_PRIVATE_KEY=

# ── Delegatee (smart account that receives delegated authority) ─────────────────
# The delegatee acts on behalf of the delegator within the delegation scope
DELEGATE_EOA_ADDRESS=
DELEGATE_SA_ADDRESS=
DELEGATE_PRIVATE_KEY=

# ── Target ────────────────────────────────────────────────────────────────────
# Target address for transfers and other on-chain operations
TARGET_ADDRESS=
